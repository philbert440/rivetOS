{
  "name": "rivetos",
  "version": "0.0.5",
  "private": true,
  "description": "Lightweight, stable agent runtime. Zero bloat. Zero lock-in. Just the loop.",
  "license": "Apache-2.0",
  "author": "Philip Tompkins",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philbert440/rivetOS.git"
  },
  "keywords": [
    "ai",
    "agent",
    "runtime",
    "llm",
    "telegram",
    "discord",
    "typescript",
    "open-source",
    "claude",
    "grok",
    "gemini",
    "ollama"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "axios": "^1.14.0",
    "tar": "^7.5.11"
  },
  "workspaces": [
    "packages/*",
    "plugins/channels/*",
    "plugins/memory/*",
    "plugins/providers/*",
    "plugins/tools/*"
  ],
  "bin": {
    "rivetos": "./packages/cli/src/index.ts"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "ci": "nx run-many -t lint build test",
    "dev": "tsx packages/cli/src/index.ts start",
    "cli": "tsx packages/cli/src/index.ts",
    "graph": "nx graph"
  },
  "bugs": {
    "url": "https://github.com/philbert440/rivetOS/issues"
  },
  "homepage": "https://rivetos.dev",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/js": "^22.6.4",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nx": "^22.6.4",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/pg": "^8.20.0",
    "discord.js": "^14.26.2",
    "grammy": "^1.42.0",
    "pg": "^8.20.0",
    "yaml": "^2.8.3"
  }
}
