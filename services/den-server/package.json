{
  "name": "@rivetos/den-server",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "rivet-den per-node service \u2014 protocol event ingest, WS fanout, replay snapshots, layout store, pack/viewer static serving",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src/ package.json",
    "test": "vitest run",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rivetos/den-protocol": "0.1.0",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "nx": {
    "tags": [
      "scope:app",
      "type:app",
      "domain:interfaces"
    ]
  }
}
