{
  "name": "infra",
  "sourceRoot": "infra/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p infra/tsconfig.json"
      },
      "inputs": ["default", "^default"],
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p infra/tsconfig.json"
      },
      "inputs": ["default", "^default"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint infra/src/"
      }
    }
  }
}
