{
  "name": "container-rivetos",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "infra/containers/rivetos",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [],
      "inputs": [
        "{projectRoot}/Dockerfile",
        "{workspaceRoot}/scripts/bundle.mjs",
        "{workspaceRoot}/packages/*/package.json",
        "{workspaceRoot}/packages/*/src/**/*",
        "{workspaceRoot}/plugins/**/package.json",
        "{workspaceRoot}/plugins/**/src/**/*",
        "{workspaceRoot}/services/*/package.json",
        "{workspaceRoot}/services/*/**/*.js",
        "{workspaceRoot}/deploy/schema/migrate.mjs",
        "{workspaceRoot}/deploy/schema/migrations/*.sql",
        "{workspaceRoot}/package.json",
        "{workspaceRoot}/package-lock.json",
        "{workspaceRoot}/tsconfig.base.json"
      ],
      "outputs": [],
      "cache": false,
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "docker build -f infra/containers/rivetos/Dockerfile -t rivetos:latest -t rivetos:$(git rev-parse --short HEAD) ."
      },
      "configurations": {
        "no-cache": {
          "command": "docker build --no-cache -f infra/containers/rivetos/Dockerfile -t rivetos:latest -t rivetos:$(git rev-parse --short HEAD) ."
        }
      }
    }
  }
}
