{
  "name": "container-agent",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "infra/containers/agent",
  "tags": ["scope:app", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [],
      "inputs": [
        "{projectRoot}/Dockerfile",
        "{workspaceRoot}/packages/*/package.json",
        "{workspaceRoot}/packages/*/src/**/*",
        "{workspaceRoot}/plugins/**/package.json",
        "{workspaceRoot}/plugins/**/src/**/*",
        "{workspaceRoot}/package.json",
        "{workspaceRoot}/package-lock.json",
        "{workspaceRoot}/tsconfig.base.json"
      ],
      "outputs": [],
      "cache": false,
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "docker build -f infra/containers/agent/Dockerfile -t rivetos-agent:latest -t rivetos-agent:$(git rev-parse --short HEAD) ."
      },
      "configurations": {
        "no-cache": {
          "command": "docker build --no-cache -f infra/containers/agent/Dockerfile -t rivetos-agent:latest -t rivetos-agent:$(git rev-parse --short HEAD) ."
        }
      }
    }
  }
}
