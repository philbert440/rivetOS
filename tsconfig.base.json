{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "paths": {
      "@rivetos/types": ["./packages/types/src/index.ts"],
      "@rivetos/core": ["./packages/core/src/index.ts"],
      "@rivetos/boot": ["./packages/boot/src/index.ts"],
      "@rivetos/cli": ["./packages/cli/src/index.ts"],
      "@rivetos/nx": ["./packages/nx-plugin/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
