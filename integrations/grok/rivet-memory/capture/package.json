    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx test/smoke.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0"
  }
}
