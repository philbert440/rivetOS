{
  "description": "rivet-den event capture for Grok Build. Install at ~/.grok/hooks/rivet-den.json (NOT config.toml). Event names are the REAL Grok events per ~/.grok/docs/user-guide/10-hooks.md (grok v0.1.219) — Stop and PreCompact, not the TurnAfter/CompactBefore fakes an earlier rivet-memory integration shipped. The event name is passed as an argument because grok payloads omit hook_event_name. Matchers are regex in Grok, hence '.*' not '*'.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${RIVETOS_ROOT:-/opt/rivetos}/integrations/grok/rivet-den/bin/grok-den-hook.sh SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${RIVETOS_ROOT:-/opt/rivetos}/integrations/grok/rivet-den/bin/grok-den-hook.sh SessionEnd",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${RIVETOS_ROOT:-/opt/rivetos}/integrations/grok/rivet-den/bin/grok-den-hook.sh UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${RIVETOS_ROOT:-/opt/rivetos}/integrations/grok/rivet-den/bin/grok-den-hook.sh PreToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${RIVETOS_ROOT:-/opt/rivetos}/integrations/grok/rivet-den/bin/grok-den-hook.sh PostToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${RIVETOS_ROOT:-/opt/rivetos}/integrations/grok/rivet-den/bin/grok-den-hook.sh PostToolUseFailure",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${RIVETOS_ROOT:-/opt/rivetos}/integrations/grok/rivet-den/bin/grok-den-hook.sh Stop",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${RIVETOS_ROOT:-/opt/rivetos}/integrations/grok/rivet-den/bin/grok-den-hook.sh PreCompact",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
