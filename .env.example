# RivetOS Environment — copy to .env and fill in your values.
# Generated values: rivetos init creates this automatically.
# DO NOT commit the actual .env file.

# ─── AI Provider Keys ────────────────────────────────────────────────────────
# Set the ones you need based on your configured agents.

ANTHROPIC_API_KEY=sk-ant-...
# XAI_API_KEY=xai-...
# GOOGLE_API_KEY=AIza...
# OPENAI_API_KEY=sk-...

# ─── Channel Tokens ──────────────────────────────────────────────────────────

DISCORD_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN=

# ─── Database ─────────────────────────────────────────────────────────────────

POSTGRES_USER=rivetos
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rivetos

# Connection string used by agents (datahub = docker service name)
RIVETOS_PG_URL=postgresql://rivetos:changeme@datahub:5432/rivetos

# ─── Optional ─────────────────────────────────────────────────────────────────

# Container registry (for rivetos build --push)
# RIVETOS_REGISTRY=ghcr.io/your-username

# Postgres port exposed on host (default: 5432, set to 0 to disable)
# POSTGRES_PORT=5432
