+/* --- Rivet: Android has no /etc/passwd; synthesize the login user from env.
+ * Linked with -Wl,--wrap=getpwnam,--wrap=getpwuid so dropbear's lookups hit these. */
+#include <pwd.h>
+static struct passwd rivet__pw;
+static struct passwd *rivet__fill(void) {
+    rivet__pw.pw_name = (char *)"rivet";
+    rivet__pw.pw_passwd = (char *)"!!";
+    rivet__pw.pw_uid = getuid();
+    rivet__pw.pw_gid = getgid();
+    rivet__pw.pw_gecos = (char *)"Rivet";
+    { char *d = getenv("RIVET_PW_DIR");   rivet__pw.pw_dir   = d ? d : (char *)"/"; }
+    { char *s = getenv("RIVET_PW_SHELL"); rivet__pw.pw_shell = s ? s : (char *)"/bin/sh"; }
+    return &rivet__pw;
+}
+struct passwd *__wrap_getpwnam(const char *name) { (void)name; return rivet__fill(); }
+struct passwd *__wrap_getpwuid(uid_t uid) { (void)uid; return rivet__fill(); }
