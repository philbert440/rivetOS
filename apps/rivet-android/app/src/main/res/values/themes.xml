<?xml version="1.0" encoding="utf-8"?>
<resources>

  <style name="Theme.Rivethub" parent="Theme.Material3.DayNight.NoActionBar" />

  <!-- Android 12+ system splash: den-bot launcher icon on dark brand bg.
       postSplashScreenTheme restores Theme.Rivethub after installSplashScreen(). -->
  <style name="Theme.Rivethub.Splash" parent="Theme.SplashScreen">
    <item name="windowSplashScreenBackground">@color/rivet_splash_bg</item>
    <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
    <item name="postSplashScreenTheme">@style/Theme.Rivethub</item>
  </style>
</resources>
