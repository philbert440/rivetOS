{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RivetHub",
  "version": "0.4.0",
  "identifier": "dev.rivetos.rivethub",
  "build": {
    "frontendDist": "../../rivethub-web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RivetHub",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "backgroundColor": "#0d1117"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "RivetHub"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
