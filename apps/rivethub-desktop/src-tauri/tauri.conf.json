{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RivetHub",
  "version": "0.4.0",
  "identifier": "dev.rivetos.rivethub",
  "build": {
    "frontendDist": "../../rivethub-web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RivetHub",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "backgroundColor": "#0d1117"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: http: https:; font-src 'self' data:; connect-src 'self' http: https: ws: wss:; frame-src http: https:; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
