---
// Wraps Starlight's default footer (prev/next, edit link, last updated) and
// appends site-wide legal links.
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default><slot /></Default>

<div class="rivet-legal-footer">
  <a href="/terms/">Terms</a>
  <span aria-hidden="true">·</span>
  <a href="/privacy/">Privacy</a>
  <span aria-hidden="true">·</span>
  <a href="https://github.com/philbert440/rivetos">GitHub</a>
</div>

<style>
  .rivet-legal-footer {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--sl-color-gray-5);
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    align-items: center;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }
  .rivet-legal-footer a {
    color: var(--sl-color-gray-3);
    text-decoration: none;
  }
  .rivet-legal-footer a:hover {
    color: var(--sl-color-text-accent);
    text-decoration: underline;
  }
</style>
