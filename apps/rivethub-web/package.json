{
  "name": "@rivetos/rivethub-web",
  "version": "0.4.0-beta.6",
  "private": true,
  "type": "module",
  "description": "RivetHub web client — chat-first UI over the gateway API; served as static assets by den-server",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-den.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src/ package.json",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@radix-ui/react-popover": "^1.1.2",
    "@rivetos/gateway-client": "*",
    "@rivetos/types": "*",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.130.0",
    "@types/qrcode": "^1.5.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.1.0",
    "vite": "^8.1.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "nx": {
    "tags": [
      "scope:app",
      "type:app",
      "domain:interfaces"
    ],
    "targets": {
      "build": {
        "dependsOn": [
          "^build"
        ]
      }
    }
  }
}
