{
  "name": "@rivetos/channel-telegram",
  "version": "0.4.0-beta.2",
  "description": "Telegram channel — grammY, Bot API, streaming message edits",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src/",
    "test": "echo \"no tests yet\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@rivetos/types": "0.4.0-beta.2",
    "grammy": "^1.42.0"
  },
  "rivetos": {
    "type": "channel",
    "name": "telegram"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philbert440/rivetOS.git",
    "directory": "plugins/channels/telegram"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
