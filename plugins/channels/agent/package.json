{
  "name": "@rivetos/channel-agent",
  "version": "0.4.0",
  "description": "Agent-to-agent channel — HTTP endpoint for cross-instance messaging",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@rivetos/types": "*"
  },
  "devDependencies": {
    "vitest": "^3.2.1"
  },
  "rivetos": {
    "type": "channel",
    "name": "agent"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philbert440/rivetOS.git",
    "directory": "plugins/channels/agent"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
