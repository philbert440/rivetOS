import { describe, it, expect } from 'vitest'
import { <%= className %>, createTools } from './index.js'

describe('<%= className %>', () => {
  it('should have correct name and description', () => {
    const tool = new <%= className %>()
    expect(tool.name).toBe('<%= name %>')
    expect(tool.description).toBeDefined()
  })

  it('should define parameters schema', () => {
    const tool = new <%= className %>()
    expect(tool.parameters).toBeDefined()
    expect(tool.parameters.type).toBe('object')
  })

  it('should execute with valid input', async () => {
    const tool = new <%= className %>()
    const result = await tool.execute({ input: 'test' })
    expect(result).toContain('test')
  })

  it('should respect abort signal', async () => {
    const tool = new <%= className %>()
    const controller = new AbortController()
    controller.abort()
    await expect(tool.execute({ input: 'test' }, controller.signal)).rejects.toThrow()
  })

  it('should export createTools factory', () => {
    const tools = createTools()
    expect(tools).toHaveLength(1)
    expect(tools[0].name).toBe('<%= name %>')
  })
})
