{
  "name": "@rivetos/nx",
  "version": "0.4.0-beta.6",
  "description": "Nx plugin for RivetOS — generators and executors for the agent runtime monorepo",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "generators": "./generators.json",
  "executors": "./executors.json",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src/ package.json",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@nx/devkit": "^22.6.4",
    "enquirer": "^2.4.1"
  },
  "peerDependencies": {
    "nx": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philbert440/rivetOS.git",
    "directory": "packages/nx-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "nx": {
    "tags": [
      "scope:tooling",
      "type:lib"
    ]
  }
}
